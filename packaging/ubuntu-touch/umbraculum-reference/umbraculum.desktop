[Desktop Entry]
Name=Umbraculum
Comment=Umbraculum operator workspace (web)
Exec=webapp-container --name=Umbraculum --icon=assets/icon.svg --store-session-cookies --enable-back-forward --webappUrlPatterns=https://demo.umbraculum.dev/* https://demo.umbraculum.dev/en/dashboard
Icon=assets/icon.svg
Terminal=false
Type=Application
X-Ubuntu-Touch=true
