{
  "name": "@umbraculum/docs-site",
  "private": true,
  "version": "0.0.1",
  "description": "Docusaurus static documentation site for Umbraculum (build-only workspace).",
  "scripts": {
    "prestart": "node scripts/copy-brand-assets.mjs",
    "start": "docusaurus start --host 0.0.0.0 --port 3000",
    "prebuild": "node scripts/copy-brand-assets.mjs",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-common": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.49.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
