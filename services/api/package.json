{
  "name": "@brewery/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:backfill:recipe-styles": "tsx src/cli/backfillRecipeStyleKeys.ts",
    "db:backfill:recipe-beerjson": "tsx src/cli/backfillRecipeBeerJson.ts",
    "test:db:prepare": "DATABASE_URL=$DATABASE_URL_TEST prisma migrate deploy && DATABASE_URL=$DATABASE_URL_TEST prisma db seed",
    "test": "npm run test:db:prepare && vitest run",
    "seed:import": "tsx src/cli/seed-import.ts",
    "job:beerproto-sync": "tsx src/jobs/beerprotoSync.ts",
    "job:session-cleanup": "tsx src/jobs/sessionCleanup.ts"
  },
  "dependencies": {
    "@beerjson/beerjson": "^1.0.2",
    "@brewery/contracts": "file:../../packages/contracts",
    "@brewery/core": "file:../../packages/core",
    "@fastify/cors": "^10.0.0",
    "@fastify/cookie": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "ajv": "^8.18.0",
    "argon2": "^0.43.0",
    "csv-parse": "^6.1.0",
    "fast-xml-parser": "^5.3.6",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
