/**
 * Per-workspace AI consultant configuration. One row per workspace.
 *
 * - `encryptedKey` stores a BYOK provider API key encrypted at rest via
 *   AES-256-GCM (keyVault.ts). Never returned to clients.
 * - `roleLimits` is `{ [WorkspaceRole]: number }` — per-role monthly token
 *   cap (sum of tokensIn + tokensOut over trailing 30 days). 0 / missing
 *   key = no role cap.
 * - `perUserDailyCap` is the per-user daily token ceiling (tokensIn +
 *   tokensOut today). Default 200_000 tokens/day ≈ $0.60/user/day at
 *   current Claude Sonnet pricing.
 * - Cancellation discipline (internal/MOAT-AND-COMPETITIVE-STRATEGY.md):
 *   when a workspace downgrades back to `free`, this row is preserved so
 *   the memory asset survives churn and can be re-activated on re-upgrade.
 */
model WorkspaceAiSettings {
  workspaceId          String      @id @map("workspace_id")
  provider             AiProvider  @default(anthropic)
  encryptedKey         String?     @map("encrypted_key")
  enabled              Boolean     @default(false)
  roleLimits           Json        @default("{}") @map("role_limits")
  perUserDailyCap      Int         @default(200000) @map("per_user_daily_cap")
  dataEgressAccepted   Boolean     @default(false) @map("data_egress_accepted")
  dataEgressAcceptedAt DateTime?   @map("data_egress_accepted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_ai_settings")
  @@schema("platform")
}

/**
 * Per-workspace operational memory — the moat.
 *
 * `memoryBlob` is the serialized {@link WorkspaceAiMemoryBlob} from
 * `services/api/src/services/ai/promptComposer.ts` (facts + recurring
 * issues + lastUpdated + schemaVersion). Defaults to an empty object so
 * the very first chat turn does not need an explicit seed row.
 *
 * `version` is a monotonic row-level counter incremented by every
 * successful writer run. It is *not* the JSON's internal `schemaVersion`.
 * `lastWriterRunAt` records the most recent successful writer run; if a
 * writer fails the row is left unchanged so the next turn retries.
 *
 * The memory blob is bounded to roughly ~2k tokens (~10k characters);
 * the writer in `memoryWriter.ts` enforces the bound by pruning oldest
 * entries first. See plan §6.5 + Sprint #2 acceptance criteria.
 */
model WorkspaceAiMemory {
  workspaceId     String    @id @map("workspace_id")
  memoryBlob      Json      @default("{}") @map("memory_blob")
  version         Int       @default(0)
  lastWriterRunAt DateTime? @map("last_writer_run_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_ai_memory")
  @@schema("platform")
}

/**
 * Append-only ledger of AI chat turns. Used by:
 *   - per-role + per-user rate-limit preflight (aggregated reads)
 *   - workspace admin usage dashboard (Sprint #2)
 *   - future credit-resale reconciliation (deferred to v1.5)
 *
 * `toolCalls` is the ordered list of tool invocations during the turn; see
 * `packages/contracts/src/ai/aiUsage.ts` `AiToolCallRecord` for the shape.
 */
model AiUsageLedger {
  id                String  @id @default(uuid())
  workspaceId       String  @map("workspace_id")
  userId            String  @map("user_id")
  sessionId         String? @map("session_id")
  model             String
  tokensIn          Int     @default(0) @map("tokens_in")
  tokensOut         Int     @default(0) @map("tokens_out")
  costMicroUsd      BigInt  @default(0) @map("cost_micro_usd")
  durationMs        Int     @default(0) @map("duration_ms")
  providerRequestId String? @map("provider_request_id")
  toolCalls         Json    @default("[]") @map("tool_calls")

  createdAt DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_usage_ledger")
  @@schema("platform")
}

/**
 * Human-in-the-loop AI proposals (propose-write). Tools with scope `propose`
 * insert rows here; apply/reject are separate HTTP actions.
 */
model AiProposal {
  id           String           @id @default(uuid())
  workspaceId  String           @map("workspace_id")
  userId       String           @map("user_id")
  moduleCode   String           @map("module_code")
  proposalType String           @map("proposal_type")
  summary      String
  payloadJson  Json             @map("payload_json")
  status       AiProposalStatus @default(pending)

  createdAt  DateTime  @default(now()) @map("created_at")
  appliedAt  DateTime? @map("applied_at")
  rejectedAt DateTime? @map("rejected_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("ai_proposals")
  @@schema("platform")
}

// =============================================================================
// automation schema (Phase B foundation)
//
// First canonical-module schema split. Lives under @@schema("automation") per
// docs/design/canonical-automation-module-surface.md §7.
//
// `Vessel.equipmentProfileId` is a Prisma cross-schema FK to
// `brewery.equipment_profiles` (RFC-0010). Nullable — vessels imported from PLC
// discovery can exist without a brewery profile.
//
// Adapter contract types live in @umbraculum/automation-contracts. The Prisma
// models reference adapter kinds and contract versions as plain strings;
// type-level validation is at the service layer.
// =============================================================================

/// Runtime physical instance owned by the automation module.
/// Distinct from EquipmentProfile (brewery design-time params) — see design §4.
/// Cardinality is N:1 against EquipmentProfile (multiple physical vessels can
/// share a single design profile, e.g. four FV-15bbl-Std fermenters).
model Vessel {
  id                  String   @id @default(uuid())
  workspaceId         String   @map("workspace_id")
  /// Short workspace-unique code (e.g. "K1", "FV-1"). Stable identifier used
  /// in the field UI, alarm messages, and AI tool addressing.
  code                String
  displayName         String   @map("display_name")
  /// Free-form vessel taxonomy (e.g. "fermenter", "brite", "kettle", "mash_tun").
  /// Not an enum at this stage — design §4 expects this set to evolve as more
  /// adapters land; promotion to enum tracked under sub-plan #9.
  vesselKind          String   @map("vessel_kind")
  /// Cross-schema FK to brewery.equipment_profiles (RFC-0010). Nullable.
  equipmentProfileId  String?  @map("equipment_profile_id")
  adapterConnectionId String?  @map("adapter_connection_id")
  /// Operational mode reported by the adapter (e.g. "fermenter", "brite_stage_1").
  /// Adapter-defined string; the service layer validates against the active
  /// AutomationAdapterDefinition's known modes.
  mode                String?
  currentTempC        Float?   @map("current_temp_c")
  targetTempC         Float?   @map("target_temp_c")
  alarmActive         Boolean  @default(false) @map("alarm_active")
  /// Last successful adapter snapshot timestamp; null until first read.
  lastSeenAt          DateTime? @map("last_seen_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  adapterConnection AdapterConnection?      @relation(fields: [adapterConnectionId], references: [id])
  equipmentProfile  EquipmentProfile?       @relation(fields: [equipmentProfileId], references: [id], onDelete: SetNull)
  alarmEvents       AutomationAlarmEvent[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([adapterConnectionId])
  @@map("vessels")
  @@schema("automation")
}

/// Persistent record of an adapter connection (e.g. one OpenPLC bench
/// instance). Owns secrets-ref, status, and the version-handshake fields
/// (`contractVersion` / `runtimeVersion`) consumed by classifyContractVersionSkew.
model AdapterConnection {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  /// Adapter definition kind (e.g. "brewery.openplc.v1", "automation.mock.v0").
  /// Resolved at boot against the in-process adapter registry.
  adapterKind     String    @map("adapter_kind")
  displayName     String    @map("display_name")
  /// One of: "disconnected" | "connecting" | "connected" | "error" | "version_skew".
  /// Service-layer enum; not a Prisma enum because Phase B keeps the adapter
  /// supervisor pluggable (Phase C/D may add states).
  status          String    @default("disconnected")
  /// Free-form adapter-specific config (host, port, slave-id, scan rate, ...).
  /// Schema validation lives at the adapter definition layer.
  configJson      Json      @map("config_json")
  /// Reference to a secret in the platform secret store (Phase D scope).
  /// Phase B leaves this null — mock adapter does not require secrets.
  secretRefId     String?   @map("secret_ref_id")
  /// Sister-repo MailboxSpec.contractVersion observed at last connect, used
  /// for the version handshake; mismatch policy per design §12.2.
  contractVersion String    @map("contract_version")
  /// Sister-repo PI_FIRMWARE_VERSION encoded value (decoded at the adapter
  /// boundary). Null until first successful handshake.
  runtimeVersion  String?   @map("runtime_version")
  lastSeenAt      DateTime? @map("last_seen_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  vessels Vessel[]

  @@index([workspaceId])
  @@index([adapterKind])
  @@map("adapter_connections")
  @@schema("automation")
}

/// Open / historical alarm events surfaced by the adapter or by platform-side
/// guards (e.g. version-skew alarms). Phase B: the table exists and the
/// service layer can write rows; Phase D wires up activeAlarms tools and
/// raise/clear semantics.
model AutomationAlarmEvent {
  id        String    @id @default(uuid())
  vesselId  String    @map("vessel_id")
  /// Stable alarm code (e.g. "version_skew.major", "mailbox.mismatch",
  /// "vessel.cold_low.latched"). Used for de-duplication and AI tool filtering.
  code      String
  /// One of: "info" | "warning" | "error" | "critical".
  severity  String
  message   String
  active    Boolean   @default(true)
  raisedAt  DateTime  @default(now()) @map("raised_at")
  clearedAt DateTime? @map("cleared_at")

  vessel Vessel @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@index([vesselId, active])
  @@index([code, active])
  @@map("alarm_events")
  @@schema("automation")
}

// =============================================================================
// Canonical `pim` module — RFC-0004 Phase B read path.
// =============================================================================

model PimProduct {
  id                    String   @id @default(uuid())
  workspaceId           String   @map("workspace_id")
  sku                   String
  name                  String
  description           String?
  primaryAttributeSetId String?  @map("primary_attribute_set_id")
  status                String   @default("draft")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  primaryAttributeSet PimAttributeSet? @relation(fields: [primaryAttributeSetId], references: [id], onDelete: SetNull)
  variants            PimVariant[]
  mediaAssetRefs      PimMediaAssetRef[]

  @@unique([workspaceId, sku])
  @@index([workspaceId])
  @@map("products")
  @@schema("pim")
}

model PimVariant {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  sku             String
  name            String
  attributeValues Json     @default("{}") @map("attribute_values")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product PimProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sku])
  @@index([productId])
  @@map("variants")
  @@schema("pim")
}

model PimAttributeSet {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  code         String
  label        String
  attributeIds String[] @map("attribute_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products PimProduct[]

  @@unique([workspaceId, code])
  @@map("attribute_sets")
  @@schema("pim")
}

model PimAttribute {
  id            String   @id @default(uuid())
  workspaceId   String   @map("workspace_id")
  code          String
  type          String
  label         String
  required      Boolean  @default(false)
  defaultValue  Json?    @map("default_value")
  selectOptions Json?    @map("select_options")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, code])
  @@map("attributes")
  @@schema("pim")
}

model PimCategory {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  code        String
  label       String
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   PimCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children PimCategory[] @relation("CategoryTree")

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@map("categories")
  @@schema("pim")
}

model PimMediaAssetRef {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  mediaAssetId String   @map("media_asset_id")
  role         String
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product PimProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("media_asset_refs")
  @@schema("pim")
}

// =============================================================================
// Canonical `mrp` module — Wave 1 read-only API skeleton.
// =============================================================================

model MrpProductionOrder {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  orderNumber     String    @map("order_number")
  status          String    @default("planned")
  sourceModule    String?   @map("source_module")
  sourceRefId     String?   @map("source_ref_id")
  outputProductId String?   @map("output_product_id")
  outputVariantId String?   @map("output_variant_id")
  quantity        Float
  unit            String
  plannedStartAt  DateTime? @map("planned_start_at")
  dueAt           DateTime? @map("due_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lines                MrpProductionOrderLine[]
  operations           MrpOperation[]
  materialRequirements MrpMaterialRequirement[]

  @@unique([workspaceId, orderNumber])
  @@index([workspaceId])
  @@index([status])
  @@map("production_orders")
  @@schema("mrp")
}

model MrpProductionOrderLine {
  id                String  @id @default(uuid())
  productionOrderId String  @map("production_order_id")
  lineNumber        Int     @map("line_number")
  outputProductId   String? @map("output_product_id")
  outputVariantId   String? @map("output_variant_id")
  description       String?
  quantity          Float
  unit              String

  productionOrder MrpProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@unique([productionOrderId, lineNumber])
  @@index([productionOrderId])
  @@map("production_order_lines")
  @@schema("mrp")
}

model MrpBom {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  code        String
  name        String
  ownerModule String? @map("owner_module")
  sourceRefId String? @map("source_ref_id")

  lines MrpBomLine[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@map("boms")
  @@schema("mrp")
}

model MrpBomLine {
  id                String  @id @default(uuid())
  bomId             String  @map("bom_id")
  lineNumber        Int     @map("line_number")
  materialRefModule String? @map("material_ref_module")
  materialRefId     String? @map("material_ref_id")
  description       String
  quantity          Float
  unit              String
  lossPercent       Float?  @map("loss_percent")

  bom                  MrpBom @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialRequirements MrpMaterialRequirement[]

  @@unique([bomId, lineNumber])
  @@index([bomId])
  @@map("bom_lines")
  @@schema("mrp")
}

model MrpOperation {
  id                     String    @id @default(uuid())
  workspaceId            String    @map("workspace_id")
  productionOrderId      String    @map("production_order_id")
  sequence               Int
  code                   String
  name                   String
  requiredResourceKind   String?   @map("required_resource_kind")
  plannedDurationMinutes Int?      @map("planned_duration_minutes")
  earliestStartAt        DateTime? @map("earliest_start_at")
  dueAt                  DateTime? @map("due_at")

  productionOrder MrpProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@unique([productionOrderId, sequence])
  @@index([workspaceId])
  @@index([productionOrderId])
  @@map("operations")
  @@schema("mrp")
}

model MrpMaterialRequirement {
  id                 String  @id @default(uuid())
  workspaceId        String  @map("workspace_id")
  productionOrderId  String  @map("production_order_id")
  bomLineId          String? @map("bom_line_id")
  materialRefModule  String? @map("material_ref_module")
  materialRefId      String? @map("material_ref_id")
  description        String
  requiredQuantity   Float   @map("required_quantity")
  unit               String
  availabilityStatus String  @default("planned") @map("availability_status")
  availabilityNote   String? @map("availability_note")

  productionOrder MrpProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  bomLine         MrpBomLine?        @relation(fields: [bomLineId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([productionOrderId])
  @@index([bomLineId])
  @@map("material_requirements")
  @@schema("mrp")
}

// =============================================================================
// Canonical `crp` module — Wave 1 read-only API skeleton.
// =============================================================================

model CrpResource {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  code         String
  name         String
  kind         String
  status       String   @default("active")
  sourceModule String?  @map("source_module")
  sourceRefId  String?  @map("source_ref_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  calendars           CrpResourceCalendar[]
  workCenters         CrpWorkCenter[]
  scheduledOperations CrpScheduledOperation[]
  conflicts           CrpCapacityConflict[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([kind])
  @@map("resources")
  @@schema("crp")
}

model CrpWorkCenter {
  id                     String   @id @default(uuid())
  workspaceId            String   @map("workspace_id")
  code                   String
  name                   String
  resourceId             String?  @map("resource_id")
  status                 String   @default("active")
  sourceModule           String?  @map("source_module")
  sourceRefId            String?  @map("source_ref_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  resource            CrpResource?          @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  scheduledOperations CrpScheduledOperation[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([resourceId])
  @@map("work_centers")
  @@schema("crp")
}

model CrpResourceCalendar {
  id         String @id @default(uuid())
  workspaceId String @map("workspace_id")
  resourceId String @map("resource_id")
  code       String
  name       String
  timezone   String @default("UTC")

  resource CrpResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  windows  CrpAvailabilityWindow[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([resourceId])
  @@map("resource_calendars")
  @@schema("crp")
}

model CrpAvailabilityWindow {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  calendarId      String   @map("calendar_id")
  resourceId      String   @map("resource_id")
  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  capacityMinutes Int      @map("capacity_minutes")
  sourceModule    String?  @map("source_module")
  sourceRefId     String?  @map("source_ref_id")

  calendar CrpResourceCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([calendarId])
  @@index([resourceId])
  @@index([startsAt, endsAt])
  @@map("availability_windows")
  @@schema("crp")
}

model CrpScheduledOperation {
  id                     String   @id @default(uuid())
  workspaceId            String   @map("workspace_id")
  resourceId             String?  @map("resource_id")
  workCenterId           String?  @map("work_center_id")
  productionOrderId      String?  @map("production_order_id")
  operationId            String?  @map("operation_id")
  operationCode          String   @map("operation_code")
  name                   String
  status                 String   @default("scheduled")
  sourceModule           String?  @map("source_module")
  sourceRefId            String?  @map("source_ref_id")
  startsAt               DateTime @map("starts_at")
  endsAt                 DateTime @map("ends_at")
  plannedDurationMinutes Int      @map("planned_duration_minutes")

  resource   CrpResource?   @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  workCenter CrpWorkCenter? @relation(fields: [workCenterId], references: [id], onDelete: SetNull)
  conflicts  CrpCapacityConflict[]

  @@index([workspaceId])
  @@index([resourceId])
  @@index([workCenterId])
  @@index([startsAt, endsAt])
  @@map("scheduled_operations")
  @@schema("crp")
}

model CrpCapacityConflict {
  id                   String    @id @default(uuid())
  workspaceId          String    @map("workspace_id")
  severity             String
  status               String    @default("open")
  message              String
  resourceId           String?   @map("resource_id")
  scheduledOperationId String?   @map("scheduled_operation_id")
  startsAt             DateTime? @map("starts_at")
  endsAt               DateTime? @map("ends_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  resource           CrpResource?           @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  scheduledOperation CrpScheduledOperation? @relation(fields: [scheduledOperationId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([resourceId])
  @@index([scheduledOperationId])
  @@index([status])
  @@map("capacity_conflicts")
  @@schema("crp")
}

// =============================================================================
// Canonical rendering pipeline — RFC-0007 PR3 job-runner state.
// =============================================================================

model RenderJob {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  requestedById String  @map("requested_by_id")
  templateRef  String   @map("template_ref")
  kind         String
  status       String
  deliveryMode String   @map("delivery_mode")
  deliveryJson Json     @map("delivery_json")
  inputJson    Json     @map("input_json")
  requestedAt  DateTime @default(now()) @map("requested_at")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  mediaAssetId String?  @map("media_asset_id")
  error        Json?

  attempts RenderJobAttempt[]
  artifact RenderArtifact?

  @@index([workspaceId, status, requestedAt])
  @@index([templateRef])
  @@index([requestedById])
  @@map("render_jobs")
  @@schema("rendering")
}

model RenderJobAttempt {
  id            String   @id @default(uuid())
  jobId         String   @map("job_id")
  attemptNumber Int     @map("attempt_number")
  startedAt     DateTime @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  error         Json?

  job RenderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, attemptNumber])
  @@index([jobId])
  @@map("render_job_attempts")
  @@schema("rendering")
}

model RenderArtifact {
  id                String   @id @default(uuid())
  jobId             String   @unique @map("job_id")
  workspaceId        String  @map("workspace_id")
  contentType        String  @map("content_type")
  filename           String
  filenameExtension  String  @map("filename_extension")
  sha256             String
  bytes              Int
  body               Bytes
  expiresAt          DateTime @map("expires_at")
  createdAt          DateTime @default(now()) @map("created_at")

  job RenderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiresAt])
  @@map("render_artifacts")
  @@schema("rendering")
}
