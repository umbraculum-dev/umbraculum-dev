generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum WorkspaceRole {
  brewery_admin
  member
  viewer

  @@map("workspace_role")
}

enum AdPlacement {
  global_top
  global_bottom
  recipe_edit_after_fermentables
  recipe_edit_after_hops
  recipe_edit_after_yeast

  @@map("ad_placement")
}

enum AdPlatform {
  web

  @@map("ad_platform")
}

enum WaterProfileScope {
  system
  account
  public

  @@map("water_profile_scope")
}

enum WaterProfileType {
  water
  dilution

  @@map("water_profile_type")
}

enum WaterProfileVerificationStatus {
  unverified
  verified

  @@map("water_profile_verification_status")
}

enum IngredientKind {
  fermentable
  hop
  yeast

  @@map("ingredient_kind")
}

enum ColorUnit {
  ebc
  srm
  lovibond
  unknown

  @@map("color_unit")
}

enum BrewSessionStatus {
  draft
  running
  paused
  stopped

  @@map("brew_session_status")
}

enum BrewSessionStepStatus {
  pending
  done
  skipped
  not_applicable

  @@map("brew_session_step_status")
}

enum BrewSessionStepTimerState {
  idle
  running
  paused
  stopped

  @@map("brew_session_step_timer_state")
}

enum BrewSessionLogKind {
  session_created
  session_started
  session_paused
  session_stopped
  steps_saved
  step_status_saved
  step_timer_started
  step_timer_paused
  step_timer_stopped

  @@map("brew_session_log_kind")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String?  @map("password_hash")
  preferredLocale String   @default("en") @map("preferred_locale")
  /** UI theme preset key (e.g. "default", "hc_dark", "hc_light"). */
  preferredTheme  String?  @default("default") @map("preferred_theme")
  /** UI font scale key (e.g. "sm", "md", "lg", "xl"). */
  preferredFontScale String? @default("md") @map("preferred_font_scale")
  /** UI density key (e.g. "comfortable", "compact"). */
  preferredDensity String? @default("comfortable") @map("preferred_density")
  /** Platform admin flag (not account-scoped). Enables platform-wide admin features. */
  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  memberships             WorkspaceMember[]
  sessions                Session[]
  webviewExchangeCodes    WebviewExchangeCode[]
  emailVerificationTokens EmailVerificationToken[]
  billingPurchaseIntents  BillingPurchaseIntent[]
  billingWorkspaceBinding BillingUserWorkspaceBinding?
  billingEvents           BillingEvent[]

  @@index([email])
  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  /** Optional workspace/company branding accent key (e.g. "default", "acme"). */
  brandKey  String?  @default("default") @map("brand_key")
  /** If true, ads are disabled for this workspace (platform-controlled). */
  adsDisabled Boolean @default(false) @map("ads_disabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members             WorkspaceMember[]
  sessions            Session[]             @relation("SessionActiveWorkspace")
  recipes             Recipe[]
  waterProfiles       WaterProfile[]
  equipmentProfiles   EquipmentProfile[]
  recipeWaterSettings RecipeWaterSettings[]

  fermentables Fermentable[]
  hops         Hop[]
  yeasts       Yeast[]
  brewdaySettings BrewdaySettings?
  brewSessions  BrewSession[]
  inventoryItems InventoryItem[]
  billing       WorkspaceBilling?
  billingPurchaseIntents BillingPurchaseIntent[]
  billingWorkspaceBindings BillingUserWorkspaceBinding[]
  billingEvents BillingEvent[]

  @@map("workspaces")
}

model BrewdaySettings {
  id        String   @id @default(uuid())
  workspaceId String   @unique @map("workspace_id")
  brewingType String @default("all_grain") @map("brewing_type")
  sectionsJson Json  @map("sections_json")
  customSectionsJson Json? @map("custom_sections_json")
  defaultStepsJson Json? @map("default_steps_json")
  notes     String?  @map("notes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("brewday_settings")
}

model BrewSession {
  id        String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  recipeId  String           @map("recipe_id")
  code      String

  status    BrewSessionStatus @default(draft)
  startedAt DateTime?        @map("started_at")
  pausedAt  DateTime?        @map("paused_at")
  stoppedAt DateTime?        @map("stopped_at")

  /** Optional scheduled/programmed date for the brew session (date only, no time). */
  scheduledDate DateTime?    @map("scheduled_date")

  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipe    Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  steps     BrewSessionStep[]
  logs      BrewSessionLog[]

  @@index([workspaceId])
  @@index([recipeId])
  @@index([workspaceId, recipeId])
  @@unique([workspaceId, code])
  @@map("brew_sessions")
}

model Ad {
  id        String      @id @default(uuid())
  placement AdPlacement
  platform  AdPlatform

  imageUrl String @map("image_url")
  linkUrl  String @map("link_url")
  altText  String @map("alt_text")

  isActive Boolean   @default(true) @map("is_active")
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  /** Higher values win. Used to break ties deterministically. */
  priority Int @default(0)
  /** Future-proofing: selection weight for rotation within same priority tier. */
  weight   Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([placement, platform, isActive])
  @@index([platform, isActive])
  @@index([startsAt])
  @@index([endsAt])
  @@map("ads")
}

model WorkspaceMember {
  id        String      @id @default(uuid())
  workspaceId String      @map("workspace_id")
  userId    String      @map("user_id")
  role      WorkspaceRole @default(member)
  createdAt DateTime    @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model Session {
  id              String   @id
  userId          String   @map("user_id")
  activeWorkspaceId String?  @map("active_workspace_id")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime @map("expires_at")

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeWorkspace Workspace? @relation("SessionActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  webviewExchangeCodes WebviewExchangeCode[]

  @@index([userId])
  @@index([expiresAt])
  @@index([activeWorkspaceId])
  @@map("sessions")
}

model WebviewExchangeCode {
  id        String   @id @default(uuid())
  codeHash  String   @unique @map("code_hash")
  /** Session id that created this code (traceability). */
  sessionId String   @map("session_id")
  /** User id tied to this code (authoritative for minting a cookie session). */
  userId    String   @map("user_id")
  /** Snapshot of active workspace when the code was issued (optional). */
  activeWorkspaceId String? @map("active_workspace_id")
  /** Optional audit/debug snapshot of requested redirect path. */
  requestedNextPath String? @map("requested_next_path")

  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("webview_exchange_codes")
}

model EmailVerificationToken {
  id        String    @id
  userId    String    @map("user_id")
  email     String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([email])
  @@map("email_verification_tokens")
}

model BeerStyle {
  /** Stable canonical key (e.g. "bjcp-2021:13C" or "custom"). */
  key      String  @id
  source   String  // e.g. "bjcp"
  version  String  // e.g. "2021"
  code     String  // e.g. "13C"
  name     String
  category String?
  categoryId String? @map("category_id")

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipes Recipe[]
  aliases BeerStyleAlias[]

  @@index([source, version])
  @@index([code])
  @@map("beer_styles")
}

model BeerStyleAlias {
  id       String @id @default(uuid())
  /** Stable alias key (e.g. "bjcp-2017:13C") mapping into a canonical `BeerStyle.key`. */
  aliasKey String @unique @map("alias_key")
  styleKey String @map("style_key")
  note     String?
  createdAt DateTime @default(now()) @map("created_at")

  style BeerStyle @relation(fields: [styleKey], references: [key], onDelete: Cascade)

  @@index([styleKey])
  @@map("beer_style_aliases")
}

model Recipe {
  id        String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name      String
  style     String?
  /** Version family id (all versions share this id). */
  versionGroupId String @map("version_group_id")
  /** Integer version number within `versionGroupId` (starts at 0). */
  version   Int    @default(0)
  /** Canonical style reference (preferred). */
  styleKey  String?  @map("style_key")
  notes     String?  @db.Text
  /** Canonical BeerJSON representation (Option A). */
  beerJsonRecipeJson Json? @map("beer_json_recipe_json")
  /** Internal extensions/metadata not covered by BeerJSON (Option 2.1). */
  recipeExtJson Json? @map("recipe_ext_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  waterSettings RecipeWaterSettings?
  beerStyle     BeerStyle?           @relation(fields: [styleKey], references: [key], onDelete: Restrict)
  brewSessions  BrewSession[]

  @@index([workspaceId])
  @@index([workspaceId, versionGroupId])
  @@unique([workspaceId, versionGroupId, version])
  @@index([styleKey])
  @@map("recipes")
}

model BrewSessionStep {
  id            String                   @id @default(uuid())
  brewSessionId String                   @map("brew_session_id")

  sectionId     String                   @map("section_id")
  /** Custom section display name snapshot (preset sections use i18n labels). */
  sectionName   String?                  @map("section_name")
  name          String
  isDisabled    Boolean                  @default(false) @map("is_disabled")
  sortOrder     Int                      @map("sort_order")
  minutesPlanned Int?                    @map("minutes_planned")

  status        BrewSessionStepStatus    @default(pending)
  note          String?                  @db.Text

  timerState    BrewSessionStepTimerState @default(idle) @map("timer_state")
  timerStartedAt DateTime?               @map("timer_started_at")
  timerLastStartedAt DateTime?           @map("timer_last_started_at")
  timerPausedAt DateTime?                @map("timer_paused_at")
  timerStoppedAt DateTime?               @map("timer_stopped_at")
  timerAccumulatedSeconds Int            @default(0) @map("timer_accumulated_seconds")

  /** Optional relative scheduling to another step's timer (e.g. -15 min from end of Boil). */
  relativeToStepId String?               @map("relative_to_step_id")
  /** Minutes from end of base step. Example: -15 means 15 minutes before the end. */
  offsetMinutesFromEnd Int?              @map("offset_minutes_from_end")

  /** When true, show per-step timer UI (elapsed, Start/Pause/Stop, Relative to, Offset). */
  customTimerEnabled Boolean             @default(false) @map("custom_timer_enabled")

  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  brewSession   BrewSession              @relation(fields: [brewSessionId], references: [id], onDelete: Cascade)
  logs          BrewSessionLog[]
  relativeToStep BrewSessionStep?        @relation("BrewSessionStepRelative", fields: [relativeToStepId], references: [id], onDelete: SetNull)
  relativeSteps  BrewSessionStep[]       @relation("BrewSessionStepRelative")

  @@index([brewSessionId])
  @@index([brewSessionId, sortOrder])
  @@index([sectionId])
  @@index([relativeToStepId])
  @@map("brew_session_steps")
}

model BrewSessionLog {
  id           String            @id @default(uuid())
  brewSessionId String           @map("brew_session_id")
  stepId       String?           @map("step_id")
  kind         BrewSessionLogKind
  message      String
  payloadJson  Json?             @map("payload_json")
  createdAt    DateTime          @default(now()) @map("created_at")

  brewSession  BrewSession       @relation(fields: [brewSessionId], references: [id], onDelete: Cascade)
  step         BrewSessionStep?  @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([brewSessionId])
  @@index([stepId])
  @@index([brewSessionId, createdAt])
  @@map("brew_session_logs")
}

model RecipeWaterSettings {
  id        String @id @default(uuid())
  workspaceId String @map("workspace_id")
  recipeId  String @unique @map("recipe_id")

  // Profile selections
  sourceWaterProfileId   String? @map("source_water_profile_id")
  targetWaterProfileId   String? @map("target_water_profile_id")
  dilutionWaterProfileId String? @map("dilution_water_profile_id")

  // Mixing (sheet 4 v0): tap + dilution volumes to create a mixed source profile
  tapWaterVolumeLiters      Float? @default(0) @map("tap_water_volume_liters")
  dilutionWaterVolumeLiters Float? @default(0) @map("dilution_water_volume_liters")

  // Mash water acidification inputs (liters-first)
  mashStartingAlkalinityPpmCaCO3 Float  @default(0) @map("mash_starting_alkalinity_ppm_caco3")
  mashStartingPh                 Float  @default(7.0) @map("mash_starting_ph")
  mashTargetPh                   Float  @default(5.6) @map("mash_target_ph")
  mashWaterVolumeLiters          Float  @default(20) @map("mash_water_volume_liters")
  mashAcidType                   String @default("phosphoric") @map("mash_acid_type")
  mashStrengthKind               String @default("percent") @map("mash_strength_kind")
  mashStrengthValue              Float? @map("mash_strength_value")

  // Mash water acidification last snapshot (optional)
  mashLastAcidRequiredMl          Float? @map("mash_last_acid_required_ml")
  mashLastAcidRequiredTsp         Float? @map("mash_last_acid_required_tsp")
  mashLastAcidRequiredGrams       Float? @map("mash_last_acid_required_grams")
  mashLastAcidRequiredKg          Float? @map("mash_last_acid_required_kg")
  mashLastFinalAlkalinityPpmCaCO3 Float? @map("mash_last_final_alkalinity_ppm_caco3")
  mashLastSulfateAddedPpm         Float? @map("mash_last_sulfate_added_ppm")
  mashLastChlorideAddedPpm        Float? @map("mash_last_chloride_added_ppm")
  mashLastCalculatedAt            DateTime? @map("mash_last_calculated_at")

  // Mash water acidification manual-entry mode (v0): user enters amount added; we estimate achieved pH.
  mashAcidificationMode                 String    @default("targetPh") @map("mash_acidification_mode") // "targetPh" | "manual"
  mashManualAcidAddedMl                 Float? @map("mash_manual_acid_added_ml")
  mashManualAcidAddedGrams              Float? @map("mash_manual_acid_added_grams")
  mashManualLastAchievedPh              Float? @map("mash_manual_last_achieved_ph")
  mashManualLastFinalAlkalinityPpmCaCO3 Float? @map("mash_manual_last_final_alkalinity_ppm_caco3")
  mashManualLastSulfateAddedPpm         Float? @map("mash_manual_last_sulfate_added_ppm")
  mashManualLastChlorideAddedPpm        Float? @map("mash_manual_last_chloride_added_ppm")
  mashManualLastCalculatedAt            DateTime? @map("mash_manual_last_calculated_at")

  // Mash salt additions (manual)
  mashSaltAdditionsJson   Json? @map("mash_salt_additions_json")
  mashSaltsLastResultJson Json? @map("mash_salts_last_result_json")

  // Mash overall adjustment snapshot (Sheet 5, v0): combined salts + acid output for debugging/audit.
  mashOverallLastResultJson   Json? @map("mash_overall_last_result_json")
  mashOverallLastCalculatedAt DateTime? @map("mash_overall_last_calculated_at")

  // Mash grist snapshot (imported from recipe; read-only in water calculator)
  mashGristImportedJson          Json? @map("mash_grist_imported_json")
  mashGristImportedAt            DateTime? @map("mash_grist_imported_at")
  mashGristSourceRecipeUpdatedAt DateTime? @map("mash_grist_source_recipe_updated_at")

  // Sparge acidification inputs (liters-first)
  spargeWaterProfileId             String? @map("sparge_water_profile_id")
  spargeStartingAlkalinityPpmCaCO3 Float   @default(0) @map("sparge_starting_alkalinity_ppm_caco3")
  spargeStartingPh                 Float   @default(7.0) @map("sparge_starting_ph")
  spargeTargetPh                   Float   @default(5.6) @map("sparge_target_ph")
  spargeVolumeLiters               Float   @default(20) @map("sparge_volume_liters")
  spargeAcidType                   String  @default("phosphoric") @map("sparge_acid_type")
  spargeStrengthKind               String  @default("percent") @map("sparge_strength_kind")
  spargeStrengthValue              Float? @map("sparge_strength_value")

  // Last calculated snapshot (optional)
  spargeLastAcidRequiredMl          Float? @map("sparge_last_acid_required_ml")
  spargeLastAcidRequiredTsp         Float? @map("sparge_last_acid_required_tsp")
  spargeLastAcidRequiredGrams       Float? @map("sparge_last_acid_required_grams")
  spargeLastAcidRequiredKg          Float? @map("sparge_last_acid_required_kg")
  spargeLastFinalAlkalinityPpmCaCO3 Float? @map("sparge_last_final_alkalinity_ppm_caco3")
  spargeLastSulfateAddedPpm         Float? @map("sparge_last_sulfate_added_ppm")
  spargeLastChlorideAddedPpm        Float? @map("sparge_last_chloride_added_ppm")
  spargeLastCalculatedAt            DateTime? @map("sparge_last_calculated_at")

  // Sparge acidification manual-entry mode (v0): user enters amount added; we estimate achieved pH.
  spargeAcidificationMode                 String    @default("targetPh") @map("sparge_acidification_mode") // "targetPh" | "manual"
  spargeManualAcidAddedMl                 Float? @map("sparge_manual_acid_added_ml")
  spargeManualAcidAddedGrams              Float? @map("sparge_manual_acid_added_grams")
  spargeManualLastAchievedPh              Float? @map("sparge_manual_last_achieved_ph")
  spargeManualLastFinalAlkalinityPpmCaCO3 Float? @map("sparge_manual_last_final_alkalinity_ppm_caco3")
  spargeManualLastSulfateAddedPpm         Float? @map("sparge_manual_last_sulfate_added_ppm")
  spargeManualLastChlorideAddedPpm        Float? @map("sparge_manual_last_chloride_added_ppm")
  spargeManualLastCalculatedAt            DateTime? @map("sparge_manual_last_calculated_at")

  // Sparge salt additions (manual)
  spargeSaltAdditionsJson   Json? @map("sparge_salt_additions_json")
  spargeSaltsLastResultJson Json? @map("sparge_salts_last_result_json")

  // Sparge step temperature (editable in Edit recipe when sparge is configured)
  spargeStepTemperatureC Float? @default(76) @map("sparge_step_temperature_c")

  // Boil/kettle add-on water (v0): separate from mash/sparge.
  // Profile selections (like mash)
  boilSourceWaterProfileId   String? @map("boil_source_water_profile_id")
  boilTargetWaterProfileId   String? @map("boil_target_water_profile_id")
  boilDilutionWaterProfileId String? @map("boil_dilution_water_profile_id")

  // Mixing volumes (like mash)
  boilTapWaterVolumeLiters      Float? @default(0) @map("boil_tap_water_volume_liters")
  boilDilutionWaterVolumeLiters Float? @default(0) @map("boil_dilution_water_volume_liters")

  // Boil water acidification inputs (liters-first; like sparge)
  boilStartingAlkalinityPpmCaCO3 Float  @default(0) @map("boil_starting_alkalinity_ppm_caco3")
  boilStartingPh                 Float  @default(7.0) @map("boil_starting_ph")
  boilTargetPh                   Float  @default(5.6) @map("boil_target_ph")
  boilWaterVolumeLiters          Float  @default(0) @map("boil_water_volume_liters") // derived from boilTap + boilDilution
  boilAcidType                   String @default("phosphoric") @map("boil_acid_type")
  boilStrengthKind               String @default("percent") @map("boil_strength_kind")
  boilStrengthValue              Float? @map("boil_strength_value")

  // Last calculated snapshot (optional)
  boilLastAcidRequiredMl          Float? @map("boil_last_acid_required_ml")
  boilLastAcidRequiredTsp         Float? @map("boil_last_acid_required_tsp")
  boilLastAcidRequiredGrams       Float? @map("boil_last_acid_required_grams")
  boilLastAcidRequiredKg          Float? @map("boil_last_acid_required_kg")
  boilLastFinalAlkalinityPpmCaCO3 Float? @map("boil_last_final_alkalinity_ppm_caco3")
  boilLastSulfateAddedPpm         Float? @map("boil_last_sulfate_added_ppm")
  boilLastChlorideAddedPpm        Float? @map("boil_last_chloride_added_ppm")
  boilLastCalculatedAt            DateTime? @map("boil_last_calculated_at")

  // Manual-entry mode (v0): user enters acid amount; we estimate achieved pH.
  boilAcidificationMode                 String    @default("targetPh") @map("boil_acidification_mode") // "targetPh" | "manual"
  boilManualAcidAddedMl                 Float? @map("boil_manual_acid_added_ml")
  boilManualAcidAddedGrams              Float? @map("boil_manual_acid_added_grams")
  boilManualLastAchievedPh              Float? @map("boil_manual_last_achieved_ph")
  boilManualLastFinalAlkalinityPpmCaCO3 Float? @map("boil_manual_last_final_alkalinity_ppm_caco3")
  boilManualLastSulfateAddedPpm         Float? @map("boil_manual_last_sulfate_added_ppm")
  boilManualLastChlorideAddedPpm        Float? @map("boil_manual_last_chloride_added_ppm")
  boilManualLastCalculatedAt            DateTime? @map("boil_manual_last_calculated_at")

  // Boil salt additions (manual)
  boilSaltAdditionsJson   Json? @map("boil_salt_additions_json")
  boilSaltsLastResultJson Json? @map("boil_salts_last_result_json")

  // Boil overall adjustment snapshot (v0): combined salts + acid output for debugging/audit.
  boilOverallLastResultJson   Json? @map("boil_overall_last_result_json")
  boilOverallLastCalculatedAt DateTime? @map("boil_overall_last_calculated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([workspaceId])
  @@map("recipe_water_settings")
}

model WaterProfile {
  id  String @id @default(uuid())
  key String @unique

  scope WaterProfileScope
  type  WaterProfileType

  // `workspaceId` is only set for workspace-scoped profiles and for audit of admin-created public ones.
  workspaceId String? @map("workspace_id")
  name      String

  // ppm (mg/L) ions
  calcium     Float
  magnesium   Float
  sodium      Float
  sulfate     Float
  chloride    Float
  bicarbonate Float

  // Optional pH (for sparge/mash UX; many water reports include it, but it may be unknown).
  ph Float?

  verificationStatus WaterProfileVerificationStatus @default(unverified) @map("verification_status")
  submittedByUserId  String? @map("submitted_by_user_id")
  verifiedByUserId   String? @map("verified_by_user_id")
  verifiedAt         DateTime? @map("verified_at")

  source String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([type])
  @@index([workspaceId])
  @@map("water_profiles")
}

model EquipmentProfile {
  id        String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name      String

  kettleVolumeLiters                     Float? @map("kettle_volume_liters")
  kettleLossesLiters                     Float? @map("kettle_losses_liters")
  kettleBoilEvaporationRatePercentPerHour Float? @map("kettle_boil_evaporation_rate_percent_per_hour")
  kettleCoolingShrinkagePercent          Float? @map("kettle_cooling_shrinkage_percent")
  kettleHopsAbsorptionLiters             Float? @map("kettle_hops_absorption_liters")

  mashVolumeLiters           Float? @map("mash_volume_liters")
  mashEfficiencyPercent      Float? @map("mash_efficiency_percent")
  mashLossesLiters           Float? @map("mash_losses_liters")
  mashThicknessLPerKg        Float? @map("mash_thickness_l_per_kg")
  mashGrainAbsorptionLPerKg  Float? @map("mash_grain_absorption_l_per_kg")
  mashWaterLeftoverLiters    Float? @map("mash_water_leftover_liters")

  otherLossesLiters Float? @map("other_losses_liters")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("equipment_profiles")
}

model Fermentable {
  id        String  @id @default(uuid())
  // null for system-wide canonical records; set for future workspace-specific overrides
  workspaceId String? @map("workspace_id")

  name     String
  producer String?
  group    String?
  type     String?
  country  String?
  notes    String? @db.Text

  // Color: canonical + original + convenience
  colorEbc          Float? @map("color_ebc")
  colorOriginal     Float? @map("color_original")
  colorOriginalUnit ColorUnit @default(unknown) @map("color_original_unit")
  colorLovibond     Float? @map("color_lovibond")
  colorSrm          Float? @map("color_srm")
  // BeerProto also includes a “Standard (ASBC/EBC/ION)” field; preserve verbatim.
  standard          String?

  // Potential / yield (canonical-ish; we’ll fill what we can from sources)
  potentialSg  Float? @map("potential_sg")
  yieldPercent Float? @map("yield_percent")
  ppg          Float?

  // Mash pH model parameters (v1, experimental)
  // - `mashDiPh`: distilled-water mash pH (room temp, ~20-25C)
  // - `mashTaToPh57_mEqPerKg`: titratable acidity to pH 5.7, mEq/kg (Troester-style)
  mashDiPh              Float? @map("mash_di_ph")
  mashTaToPh57_mEqPerKg Float? @map("mash_ta_to_ph57_meq_per_kg")
  mashPhModelKey        String? @map("mash_ph_model_key")
  mashPhModelSource     String? @map("mash_ph_model_source")
  mashPhModelVersion    Int? @map("mash_ph_model_version")

  deprecatedAt DateTime? @map("deprecated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  workspace  Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  sourceMaps IngredientSourceMap[]

  @@index([workspaceId])
  @@index([name])
  @@index([producer])
  @@map("fermentables")
}

model Hop {
  id        String  @id @default(uuid())
  workspaceId String? @map("workspace_id")

  name    String
  country String?
  type    String?
  notes   String? @db.Text

  // alpha/beta acids (%), often a range; keep min/max where available.
  alphaMin Float? @map("alpha_min")
  alphaMax Float? @map("alpha_max")
  betaMin  Float? @map("beta_min")
  betaMax  Float? @map("beta_max")

  deprecatedAt DateTime? @map("deprecated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  workspace  Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  sourceMaps IngredientSourceMap[]

  @@index([workspaceId])
  @@index([name])
  @@map("hops")
}

model Yeast {
  id        String  @id @default(uuid())
  workspaceId String? @map("workspace_id")

  name             String
  lab              String?
  // BeerProto "Product ID" (vendor code), e.g. "US-05"
  productId        String? @map("product_id")
  type             String?
  form             String?
  species          String?
  endPhMin         Float? @map("end_ph_min")
  endPhMax         Float? @map("end_ph_max")
  flavorAroma      String? @db.Text
  pitch            String? @db.Text
  pitchTempC       Float? @map("pitch_temp_c")
  tolerancePercent Float? @map("tolerance_percent")
  notes            String? @db.Text

  attenuationMin      Float? @map("attenuation_min")
  attenuationMax      Float? @map("attenuation_max")
  flocculationPercent Float? @map("flocculation_percent")
  tempMinC            Float? @map("temp_min_c")
  tempMaxC            Float? @map("temp_max_c")
  bestFor             String? @db.Text

  deprecatedAt DateTime? @map("deprecated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  workspace  Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  sourceMaps IngredientSourceMap[]

  @@index([workspaceId])
  @@index([name])
  @@index([lab])
  @@index([productId])
  @@index([species])
  @@map("yeasts")
}

model IngredientSource {
  id            String @id @default(uuid())
  sourceName    String @map("source_name")
  sourceUrl     String @map("source_url")
  sourceLicense String @map("source_license")
  resourcePath  String @map("resource_path")

  etag          String?
  lastCheckedAt DateTime? @map("last_checked_at")
  lastAppliedAt DateTime? @map("last_applied_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  runs IngredientImportRun[]

  @@unique([sourceName, resourcePath])
  @@index([sourceName])
  @@map("ingredient_sources")
}

model IngredientImportRun {
  id         String    @id @default(uuid())
  sourceId   String    @map("source_id")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  status     String
  statsJson  Json?     @map("stats_json")
  error      String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  source      IngredientSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  stagingRows IngredientStagingRow[]

  @@index([sourceId])
  @@index([startedAt])
  @@map("ingredient_import_runs")
}

model IngredientStagingRow {
  id             String         @id @default(uuid())
  importRunId    String         @map("import_run_id")
  kind           IngredientKind
  sourceKey      String         @map("source_key")
  rawPayloadJson Json           @map("raw_payload_json")
  warningsJson   Json?          @map("warnings_json")

  createdAt DateTime @default(now()) @map("created_at")

  importRun IngredientImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@index([kind])
  @@index([sourceKey])
  @@map("ingredient_staging_rows")
}

model IngredientSourceMap {
  id         String         @id @default(uuid())
  kind       IngredientKind
  sourceName String         @map("source_name")
  sourceKey  String         @map("source_key")

  fermentableId String?     @map("fermentable_id")
  hopId         String?     @map("hop_id")
  yeastId       String?     @map("yeast_id")

  confidence Float?    @default(1.0)
  notes      String?   @db.Text
  lastSeenAt DateTime? @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fermentable Fermentable? @relation(fields: [fermentableId], references: [id], onDelete: Cascade)
  hop         Hop?         @relation(fields: [hopId], references: [id], onDelete: Cascade)
  yeast       Yeast?       @relation(fields: [yeastId], references: [id], onDelete: Cascade)

  @@unique([kind, sourceName, sourceKey])
  @@index([sourceName])
  @@index([sourceKey])
  @@index([fermentableId])
  @@index([hopId])
  @@index([yeastId])
  @@map("ingredient_source_maps")
}

enum InventoryCategory {
  fermentable
  hop
  speciality
  acid_salt
  detergent_sanitizer
  kegging

  @@map("inventory_category")
}

enum InventoryUnit {
  kg
  g
  ml
  count

  @@map("inventory_unit")
}

model InventoryItem {
  id           String            @id @default(uuid())
  workspaceId  String            @map("workspace_id")
  category     InventoryCategory
  ingredientId String?           @map("ingredient_id")
  name         String
  quantity     Float
  unit         InventoryUnit     @default(kg)
  metadataJson Json?             @map("metadata_json")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@map("inventory_items")
}

enum BillingTier {
  free
  premium
  pro
  pro_plus

  @@map("billing_tier")
}

enum BillingSource {
  stripe
  apple
  google
  manual

  @@map("billing_source")
}

enum BillingPurchaseProvider {
  stripe
  apple
  google

  @@map("billing_purchase_provider")
}

enum BillingPurchaseIntentMode {
  purchase
  restore

  @@map("billing_purchase_intent_mode")
}

enum BillingPurchaseIntentStatus {
  created
  fulfilled
  expired
  cancelled

  @@map("billing_purchase_intent_status")
}

enum BillingEventProvider {
  stripe
  revenuecat

  @@map("billing_event_provider")
}

model WorkspaceBilling {
  id          String      @id @default(uuid())
  workspaceId String      @unique @map("workspace_id")
  tier        BillingTier @default(free)
  expiresAt   DateTime?   @map("expires_at")
  source      BillingSource @default(manual)

  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")

  /** The RevenueCat app_user_id (equals `user_id`). */
  rcAppUserId String? @map("rc_app_user_id")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([stripeSubscriptionId])
  @@map("workspace_billing")
}

model BillingPurchaseIntent {
  id String @id @default(uuid())

  userId      String @map("user_id")
  workspaceId String @map("workspace_id")

  planCode  String @map("plan_code")
  provider  BillingPurchaseProvider
  mode      BillingPurchaseIntentMode @default(purchase)
  status    BillingPurchaseIntentStatus @default(created)
  expiresAt DateTime @map("expires_at")

  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")
  stripeSubscriptionId    String? @map("stripe_subscription_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  fulfilledAt DateTime? @map("fulfilled_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, workspaceId])
  @@map("billing_purchase_intents")
}

model BillingUserWorkspaceBinding {
  userId      String @id @map("user_id")
  workspaceId String @map("workspace_id")

  provider BillingPurchaseProvider? @map("provider")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("billing_user_workspace_binding")
}

model BillingEvent {
  id String @id @default(uuid())

  provider BillingEventProvider
  externalEventId String? @unique @map("external_event_id")

  userId      String? @map("user_id")
  workspaceId String? @map("workspace_id")

  payloadJson Json @map("payload_json")

  createdAt DateTime @default(now()) @map("created_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([userId])
  @@index([workspaceId])
  @@map("billing_events")
}
