generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountRole {
  owner
  brewery_admin
  member
  viewer
}

enum WaterProfileScope {
  system
  account
  public
}

enum WaterProfileType {
  water
  dilution
}

enum WaterProfileVerificationStatus {
  unverified
  verified
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  memberships AccountMember[]

  @@index([email])
}

model Account {
  id        String          @id @default(uuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members   AccountMember[]
  recipes   Recipe[]
  waterProfiles WaterProfile[]
  recipeWaterSettings RecipeWaterSettings[]
}

model AccountMember {
  id        String      @id @default(uuid())
  accountId String
  userId    String
  role      AccountRole @default(member)
  createdAt DateTime    @default(now())

  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId])
}

model Recipe {
  id        String   @id @default(uuid())
  accountId String
  name      String
  style     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  waterSettings RecipeWaterSettings?

  @@index([accountId])
}

model RecipeWaterSettings {
  id        String   @id @default(uuid())
  accountId String
  recipeId  String   @unique

  // Profile selections
  sourceWaterProfileId   String?
  targetWaterProfileId   String?
  dilutionWaterProfileId String?

  // Mixing (sheet 4 v0): tap + dilution volumes to create a mixed source profile
  tapWaterVolumeLiters      Float? @default(0)
  dilutionWaterVolumeLiters Float? @default(0)

  // Mash water acidification inputs (liters-first)
  mashStartingAlkalinityPpmCaCO3 Float @default(0)
  mashStartingPh                Float @default(7.0)
  mashTargetPh                  Float @default(5.6)
  mashWaterVolumeLiters         Float @default(20)
  mashAcidType                  String @default("phosphoric")
  mashStrengthKind              String @default("percent")
  mashStrengthValue             Float?

  // Mash water acidification last snapshot (optional)
  mashLastAcidRequiredMl            Float?
  mashLastAcidRequiredTsp           Float?
  mashLastAcidRequiredGrams         Float?
  mashLastAcidRequiredKg            Float?
  mashLastFinalAlkalinityPpmCaCO3   Float?
  mashLastSulfateAddedPpm           Float?
  mashLastChlorideAddedPpm          Float?
  mashLastCalculatedAt              DateTime?

  // Mash water acidification manual-entry mode (v0): user enters amount added; we estimate achieved pH.
  mashAcidificationMode             String @default("targetPh") // "targetPh" | "manual"
  mashManualAcidAddedMl             Float?
  mashManualAcidAddedGrams          Float?
  mashManualLastAchievedPh          Float?
  mashManualLastFinalAlkalinityPpmCaCO3 Float?
  mashManualLastSulfateAddedPpm     Float?
  mashManualLastChlorideAddedPpm    Float?
  mashManualLastCalculatedAt        DateTime?

  // Mash salt additions (manual)
  mashSaltAdditionsJson   Json?
  mashSaltsLastResultJson Json?

  // Sparge acidification inputs (liters-first)
  spargeStartingAlkalinityPpmCaCO3 Float @default(0)
  spargeStartingPh                Float @default(7.0)
  spargeTargetPh                  Float @default(5.6)
  spargeVolumeLiters              Float @default(20)
  spargeAcidType                  String @default("phosphoric")
  spargeStrengthKind              String @default("percent")
  spargeStrengthValue             Float?

  // Last calculated snapshot (optional)
  spargeLastAcidRequiredMl            Float?
  spargeLastAcidRequiredTsp           Float?
  spargeLastAcidRequiredGrams         Float?
  spargeLastAcidRequiredKg            Float?
  spargeLastFinalAlkalinityPpmCaCO3   Float?
  spargeLastSulfateAddedPpm           Float?
  spargeLastChlorideAddedPpm          Float?
  spargeLastCalculatedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([accountId])
}

model WaterProfile {
  id        String   @id @default(uuid())
  key       String   @unique

  scope     WaterProfileScope
  type      WaterProfileType

  // `accountId` is only set for account-scoped profiles and for audit of admin-created public ones.
  accountId String?
  name      String

  // ppm (mg/L) ions
  calcium      Float
  magnesium    Float
  sodium       Float
  sulfate      Float
  chloride     Float
  bicarbonate  Float

  verificationStatus WaterProfileVerificationStatus @default(unverified)
  submittedByUserId  String?
  verifiedByUserId   String?
  verifiedAt         DateTime?

  source    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([type])
  @@index([accountId])
}

