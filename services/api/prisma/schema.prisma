generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountRole {
  owner
  brewery_admin
  member
  viewer
}

enum WaterProfileScope {
  system
  account
  public
}

enum WaterProfileType {
  water
  dilution
}

enum WaterProfileVerificationStatus {
  unverified
  verified
}

enum IngredientKind {
  fermentable
  hop
  yeast
}

enum ColorUnit {
  ebc
  srm
  lovibond
  unknown
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  memberships AccountMember[]

  @@index([email])
}

model Account {
  id        String          @id @default(uuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members   AccountMember[]
  recipes   Recipe[]
  waterProfiles WaterProfile[]
  recipeWaterSettings RecipeWaterSettings[]

  fermentables Fermentable[]
  hops         Hop[]
  yeasts       Yeast[]
}

model AccountMember {
  id        String      @id @default(uuid())
  accountId String
  userId    String
  role      AccountRole @default(member)
  createdAt DateTime    @default(now())

  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId])
}

model Recipe {
  id        String   @id @default(uuid())
  accountId String
  name      String
  style     String?
  notes     String?  @db.Text
  gristJson Json?
  hopsJson  Json?
  yeastJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  waterSettings RecipeWaterSettings?

  @@index([accountId])
}

model RecipeWaterSettings {
  id        String   @id @default(uuid())
  accountId String
  recipeId  String   @unique

  // Profile selections
  sourceWaterProfileId   String?
  targetWaterProfileId   String?
  dilutionWaterProfileId String?

  // Mixing (sheet 4 v0): tap + dilution volumes to create a mixed source profile
  tapWaterVolumeLiters      Float? @default(0)
  dilutionWaterVolumeLiters Float? @default(0)

  // Mash water acidification inputs (liters-first)
  mashStartingAlkalinityPpmCaCO3 Float @default(0)
  mashStartingPh                Float @default(7.0)
  mashTargetPh                  Float @default(5.6)
  mashWaterVolumeLiters         Float @default(20)
  mashAcidType                  String @default("phosphoric")
  mashStrengthKind              String @default("percent")
  mashStrengthValue             Float?

  // Mash water acidification last snapshot (optional)
  mashLastAcidRequiredMl            Float?
  mashLastAcidRequiredTsp           Float?
  mashLastAcidRequiredGrams         Float?
  mashLastAcidRequiredKg            Float?
  mashLastFinalAlkalinityPpmCaCO3   Float?
  mashLastSulfateAddedPpm           Float?
  mashLastChlorideAddedPpm          Float?
  mashLastCalculatedAt              DateTime?

  // Mash water acidification manual-entry mode (v0): user enters amount added; we estimate achieved pH.
  mashAcidificationMode             String @default("targetPh") // "targetPh" | "manual"
  mashManualAcidAddedMl             Float?
  mashManualAcidAddedGrams          Float?
  mashManualLastAchievedPh          Float?
  mashManualLastFinalAlkalinityPpmCaCO3 Float?
  mashManualLastSulfateAddedPpm     Float?
  mashManualLastChlorideAddedPpm    Float?
  mashManualLastCalculatedAt        DateTime?

  // Mash salt additions (manual)
  mashSaltAdditionsJson   Json?
  mashSaltsLastResultJson Json?

  // Mash overall adjustment snapshot (Sheet 5, v0): combined salts + acid output for debugging/audit.
  mashOverallLastResultJson   Json?
  mashOverallLastCalculatedAt DateTime?

  // Mash grist snapshot (imported from recipe; read-only in water calculator)
  mashGristImportedJson           Json?
  mashGristImportedAt             DateTime?
  mashGristSourceRecipeUpdatedAt  DateTime?

  // Sparge acidification inputs (liters-first)
  spargeWaterProfileId             String?
  spargeStartingAlkalinityPpmCaCO3 Float @default(0)
  spargeStartingPh                Float @default(7.0)
  spargeTargetPh                  Float @default(5.6)
  spargeVolumeLiters              Float @default(20)
  spargeAcidType                  String @default("phosphoric")
  spargeStrengthKind              String @default("percent")
  spargeStrengthValue             Float?

  // Last calculated snapshot (optional)
  spargeLastAcidRequiredMl            Float?
  spargeLastAcidRequiredTsp           Float?
  spargeLastAcidRequiredGrams         Float?
  spargeLastAcidRequiredKg            Float?
  spargeLastFinalAlkalinityPpmCaCO3   Float?
  spargeLastSulfateAddedPpm           Float?
  spargeLastChlorideAddedPpm          Float?
  spargeLastCalculatedAt              DateTime?

  // Sparge acidification manual-entry mode (v0): user enters amount added; we estimate achieved pH.
  spargeAcidificationMode             String @default("targetPh") // "targetPh" | "manual"
  spargeManualAcidAddedMl             Float?
  spargeManualAcidAddedGrams          Float?
  spargeManualLastAchievedPh          Float?
  spargeManualLastFinalAlkalinityPpmCaCO3 Float?
  spargeManualLastSulfateAddedPpm     Float?
  spargeManualLastChlorideAddedPpm    Float?
  spargeManualLastCalculatedAt        DateTime?

  // Sparge salt additions (manual)
  spargeSaltAdditionsJson   Json?
  spargeSaltsLastResultJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([accountId])
}

model WaterProfile {
  id        String   @id @default(uuid())
  key       String   @unique

  scope     WaterProfileScope
  type      WaterProfileType

  // `accountId` is only set for account-scoped profiles and for audit of admin-created public ones.
  accountId String?
  name      String

  // ppm (mg/L) ions
  calcium      Float
  magnesium    Float
  sodium       Float
  sulfate      Float
  chloride     Float
  bicarbonate  Float

  // Optional pH (for sparge/mash UX; many water reports include it, but it may be unknown).
  ph           Float?

  verificationStatus WaterProfileVerificationStatus @default(unverified)
  submittedByUserId  String?
  verifiedByUserId   String?
  verifiedAt         DateTime?

  source    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([scope])
  @@index([type])
  @@index([accountId])
}

model Fermentable {
  id        String   @id @default(uuid())
  // null for system-wide canonical records; set for future brewery-specific overrides
  accountId String?

  name      String
  producer  String?
  group     String?
  type      String?
  country   String?
  notes     String?  @db.Text

  // Color: canonical + original + convenience
  colorEbc          Float?
  colorOriginal     Float?
  colorOriginalUnit ColorUnit @default(unknown)
  colorLovibond     Float?
  colorSrm          Float?
  // BeerProto also includes a “Standard (ASBC/EBC/ION)” field; preserve verbatim.
  standard          String?

  // Potential / yield (canonical-ish; we’ll fill what we can from sources)
  potentialSg   Float?
  yieldPercent  Float?
  ppg           Float?

  // Mash pH model parameters (v1, experimental)
  // - `mashDiPh`: distilled-water mash pH (room temp, ~20-25C)
  // - `mashTaToPh57_mEqPerKg`: titratable acidity to pH 5.7, mEq/kg (Troester-style)
  mashDiPh              Float?
  mashTaToPh57_mEqPerKg Float?
  mashPhModelKey        String?
  mashPhModelSource     String?
  mashPhModelVersion    Int?

  deprecatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sourceMaps   IngredientSourceMap[]

  @@index([accountId])
  @@index([name])
  @@index([producer])
}

model Hop {
  id        String   @id @default(uuid())
  accountId String?

  name      String
  country   String?
  type      String?
  notes     String?  @db.Text

  // alpha/beta acids (%), often a range; keep min/max where available.
  alphaMin  Float?
  alphaMax  Float?
  betaMin   Float?
  betaMax   Float?

  deprecatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sourceMaps   IngredientSourceMap[]

  @@index([accountId])
  @@index([name])
}

model Yeast {
  id        String   @id @default(uuid())
  accountId String?

  name      String
  lab       String?
  // BeerProto "Product ID" (vendor code), e.g. "US-05"
  productId String?
  type      String?
  form      String?
  species   String?
  endPhMin  Float?
  endPhMax  Float?
  flavorAroma String? @db.Text
  pitch       String? @db.Text
  pitchTempC  Float?
  tolerancePercent   Float?
  notes     String?  @db.Text

  attenuationMin Float?
  attenuationMax Float?
  flocculationPercent Float?
  tempMinC       Float?
  tempMaxC       Float?
  bestFor        String? @db.Text

  deprecatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sourceMaps   IngredientSourceMap[]

  @@index([accountId])
  @@index([name])
  @@index([lab])
  @@index([productId])
  @@index([species])
}

model IngredientSource {
  id            String   @id @default(uuid())
  sourceName    String
  sourceUrl     String
  sourceLicense String
  resourcePath  String

  etag          String?
  lastCheckedAt DateTime?
  lastAppliedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs IngredientImportRun[]

  @@unique([sourceName, resourcePath])
  @@index([sourceName])
}

model IngredientImportRun {
  id        String   @id @default(uuid())
  sourceId  String
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status    String
  statsJson Json?
  error     String?  @db.Text

  createdAt DateTime @default(now())

  source IngredientSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  stagingRows IngredientStagingRow[]

  @@index([sourceId])
  @@index([startedAt])
}

model IngredientStagingRow {
  id          String         @id @default(uuid())
  importRunId String
  kind        IngredientKind
  sourceKey   String
  rawPayloadJson Json
  warningsJson   Json?

  createdAt DateTime @default(now())

  importRun IngredientImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@index([kind])
  @@index([sourceKey])
}

model IngredientSourceMap {
  id        String         @id @default(uuid())
  kind      IngredientKind
  sourceName String
  sourceKey  String

  fermentableId String?
  hopId         String?
  yeastId       String?

  confidence Float? @default(1.0)
  notes      String? @db.Text
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fermentable Fermentable? @relation(fields: [fermentableId], references: [id], onDelete: Cascade)
  hop         Hop?         @relation(fields: [hopId], references: [id], onDelete: Cascade)
  yeast       Yeast?       @relation(fields: [yeastId], references: [id], onDelete: Cascade)

  @@unique([kind, sourceName, sourceKey])
  @@index([sourceName])
  @@index([sourceKey])
  @@index([fermentableId])
  @@index([hopId])
  @@index([yeastId])
}

