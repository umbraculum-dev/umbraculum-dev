{
  "name": "@umbraculum/api-client",
  "version": "0.0.1",
  "description": "Typed API client with pluggable auth strategies (cookie sessions for web; bearer tokens for native + Node). The transport layer between any client and services/api. Returned payloads are runtime-validated by parsers from @umbraculum/contracts. Platform-classified per sub-plan #9 §1.1 — no brewery-domain logic.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umbraculum-dev/umbraculum-dev.git",
    "directory": "packages/api-client"
  },
  "bugs": {
    "url": "https://github.com/umbraculum-dev/umbraculum-dev/issues"
  },
  "homepage": "https://github.com/umbraculum-dev/umbraculum-dev/tree/main/packages/api-client#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/brewery/index.ts src/automation/index.ts src/pim/index.ts src/mrp/index.ts src/crp/index.ts --format esm,cjs --dts --out-dir dist --clean --tsconfig tsconfig.build.json",
    "openapi:codegen": "node ./scripts/openapi-codegen.mjs",
    "openapi:codegen:check": "node ./scripts/openapi-codegen.mjs --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./brewery": {
      "types": "./dist/brewery/index.d.ts",
      "import": "./dist/brewery/index.js",
      "require": "./dist/brewery/index.cjs",
      "default": "./dist/brewery/index.js"
    },
    "./automation": {
      "types": "./dist/automation/index.d.ts",
      "import": "./dist/automation/index.js",
      "require": "./dist/automation/index.cjs",
      "default": "./dist/automation/index.js"
    },
    "./pim": {
      "types": "./dist/pim/index.d.ts",
      "import": "./dist/pim/index.js",
      "require": "./dist/pim/index.cjs",
      "default": "./dist/pim/index.js"
    },
    "./mrp": {
      "types": "./dist/mrp/index.d.ts",
      "import": "./dist/mrp/index.js",
      "require": "./dist/mrp/index.cjs",
      "default": "./dist/mrp/index.js"
    },
    "./crp": {
      "types": "./dist/crp/index.d.ts",
      "import": "./dist/crp/index.js",
      "require": "./dist/crp/index.cjs",
      "default": "./dist/crp/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@umbraculum/automation-contracts": "file:../automation-contracts",
    "@umbraculum/brewery-contracts": "file:../brewery-contracts",
    "@umbraculum/contracts": "file:../contracts",
    "@umbraculum/crp-contracts": "file:../crp-contracts",
    "@umbraculum/mrp-contracts": "file:../mrp-contracts",
    "@umbraculum/pim-contracts": "file:../pim-contracts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "vitest": "^3.0.0"
  }
}
