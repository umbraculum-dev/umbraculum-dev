{
  "name": "@brewery/recipes-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@brewery/beerjson": "file:../beerjson",
    "@brewery/i18n-react": "file:../i18n-react",
    "@brewery/ui": "file:../ui",
    "tamagui": "^2.0.0-rc.11"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.70"
  }
}

