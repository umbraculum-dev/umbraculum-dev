{
  "name": "@umbraculum/web",
  "private": true,
  "version": "0.0.1",
  "description": "Umbraculum web app — Next.js storefront for the brewery vertical (recipes, brew sessions, water/yeast workflows). Consumes @umbraculum/* packages (ui, recipes-ui, contracts, i18n, etc.) via workspace symlinks. Application workspace; not imported by other workspaces.",
  "scripts": {
    "postinstall": "node scripts/sync-media.mjs",
    "predev": "node scripts/sync-media.mjs",
    "prebuild": "node scripts/sync-media.mjs",
    "prestart": "node scripts/sync-media.mjs",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "i18n:guardrail": "node scripts/i18n-guardrail.mjs"
  },
  "dependencies": {
    "@tamagui/animations-css": "^2.0.0-rc.11",
    "@tamagui/config": "^2.0.0-rc.7",
    "@tamagui/core": "^2.0.0-rc.12",
    "@umbraculum/api-client": "file:../../packages/platform/api-client",
    "@umbraculum/brewery-api-client": "file:../../packages/verticals/brewery/api-client",
    "@umbraculum/automation-contracts": "file:../../packages/modules/automation-contracts",
    "@umbraculum/brewery-beerjson": "file:../../packages/verticals/brewery/beerjson",
    "@umbraculum/brewery-contracts": "file:../../packages/verticals/brewery/contracts",
    "@umbraculum/brewery-core": "file:../../packages/verticals/brewery/core",
    "@umbraculum/brewery-i18n": "file:../../packages/verticals/brewery/i18n",
    "@umbraculum/brewery-recipes-ui": "file:../../packages/verticals/brewery/recipes-ui",
    "@umbraculum/contracts": "file:../../packages/platform/contracts",
    "@umbraculum/crp-contracts": "file:../../packages/modules/crp-contracts",
    "@umbraculum/i18n": "file:../../packages/platform/i18n",
    "@umbraculum/i18n-react": "file:../../packages/platform/i18n-react",
    "@umbraculum/media": "file:../../packages/platform/media",
    "@umbraculum/module-sdk": "file:../../packages/modules/module-sdk",
    "@umbraculum/mrp-contracts": "file:../../packages/modules/mrp-contracts",
    "@umbraculum/navigation": "file:../../packages/platform/navigation",
    "@umbraculum/pim-contracts": "file:../../packages/modules/pim-contracts",
    "@umbraculum/ui": "file:../../packages/platform/ui",
    "next": "^15.0.0",
    "next-intl": "^4.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native-web": "^0.20.0",
    "tamagui": "^2.0.0-rc.11",
    "victory": "^36.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tamagui/cli": "^2.0.0-rc.11",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-native": "^0.72.8",
    "@types/react-native-web": "^0.19.2",
    "typescript": "^5.0.0"
  }
}
