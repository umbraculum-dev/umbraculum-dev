{
  "name": "@umbraculum/web-e2e",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Umbraculum web E2E suite — Playwright tests for the @umbraculum/web storefront. Nested workspace (NOT in the root @umbraculum monorepo workspaces glob — Playwright + browser binaries are isolated per its own README and the slot-7 CI hygiene #2 lesson).",
  "scripts": {
    "test": "playwright test",
    "test:all": "playwright test",
    "test:platform": "playwright test --project=platform",
    "test:canonical": "playwright test --project=canonical",
    "test:verticals-brewery": "playwright test --project=verticals-brewery",
    "test:smoke": "playwright test",
    "test:brewday": "playwright test --project=verticals-brewery",
    "trace": "playwright show-trace",
    "install:browsers": "playwright install chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "1.60.0",
    "axe-core": "^4.10.0"
  }
}
