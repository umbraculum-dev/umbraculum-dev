{
  "name": "@umbraculum/native-brewery",
  "private": true,
  "version": "0.0.1",
  "description": "Umbraculum native app — Expo + React Native mobile client for the brewery vertical, sharing UI primitives and recipe editors with the web app via @umbraculum/{ui, brewery-recipes-ui, …}. Application workspace; not imported by other workspaces.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "i18n:guardrail": "node scripts/i18n-guardrail.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@umbraculum/native-shell": "file:../../../packages/platform/native-shell",
    "@umbraculum/api-client": "^0.0.1",
    "@umbraculum/module-sdk": "^0.0.2",
    "@umbraculum/brewery-contracts": "file:../../../packages/verticals/brewery/contracts",
    "@umbraculum/brewery-beerjson": "file:../../../packages/verticals/brewery/beerjson",
    "@umbraculum/contracts": "^0.0.1",
    "@umbraculum/i18n": "file:../../../packages/platform/i18n",
    "@umbraculum/i18n-react": "file:../../../packages/platform/i18n-react",
    "@umbraculum/media": "file:../../../packages/platform/media",
    "@umbraculum/brewery-media-assets": "file:../../../packages/verticals/brewery/media-assets",
    "@umbraculum/navigation": "file:../../../packages/platform/navigation",
    "@umbraculum/brewery-recipes-ui": "file:../../../packages/verticals/brewery/recipes-ui",
    "@umbraculum/ui": "file:../../../packages/platform/ui",
    "@react-navigation/bottom-tabs": "^7.15.0",
    "@react-navigation/native": "^7.1.29",
    "@react-navigation/native-stack": "^7.14.0",
    "@tamagui/core": "^2.0.0-rc.12",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.0",
    "expo-image": "^3.0.11",
    "expo-localization": "~17.0.9",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "tamagui": "^2.0.0-rc.11",
    "victory-native": "^36.9.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
