{
  "schemaVersion": 1,
  "profile": "ts-npm-monorepo",
  "runtime": {
    "image": "node:20-slim",
    "nodeOptions": "--max-old-space-size=6144"
  },
  "docker": {
    "volumes": [
      { "name": "umbraculum_npm_cache", "containerPath": "/root/.npm" },
      { "name": "umbraculum_root_node_modules", "containerPath": "/repo/node_modules" }
    ]
  },
  "snapshot": {
    "local": "git-archive",
    "ci": "checkout"
  },
  "install": {
    "root": "npm ci --no-audit --no-fund --prefer-offline --workspaces --include-workspace-root",
    "nested": [
      {
        "path": "apps/web/e2e",
        "command": "npm ci --no-audit --no-fund",
        "afterJob": "lint",
        "beforeJob": "typecheck"
      }
    ]
  },
  "jobs": [
    {
      "id": "docs-readmes",
      "containerSetup": [
        "apt-get update -qq >/dev/null 2>&1",
        "apt-get install -y -qq python3 >/dev/null 2>&1"
      ],
      "commands": [
        "python3 scripts/docs/check-readmes.py",
        "python3 scripts/docs/check-public-docs-no-internal-links.py",
        "python3 scripts/docs/check-public-docs-no-personal-paths.py"
      ]
    },
    {
      "id": "lint",
      "command": "npm run lint",
      "needsRootInstall": true
    },
    {
      "id": "typecheck",
      "needsRootInstall": true,
      "needsNestedInstall": true,
      "workspaces": [
        { "path": "services/api", "mode": "npm" },
        { "path": "services/api/prisma", "mode": "tsc" },
        { "path": "apps/native", "mode": "npm" },
        { "path": "apps/web/e2e", "mode": "npm" },
        { "path": "packages/platform/api-client", "mode": "npm" },
        { "path": "packages/modules/automation-contracts", "mode": "npm" },
        { "path": "packages/verticals/brewery/beerjson", "mode": "npm" },
        { "path": "packages/platform/contracts", "mode": "npm" },
        { "path": "packages/modules/module-sdk", "mode": "npm" },
        { "path": "packages/verticals/brewery/i18n", "mode": "npm" },
        { "path": "packages/platform/i18n", "mode": "npm" },
        { "path": "packages/platform/i18n-react", "mode": "npm" },
        { "path": "packages/platform/media", "mode": "npm" },
        { "path": "packages/verticals/brewery/media-assets", "mode": "npm" },
        { "path": "packages/platform/navigation", "mode": "npm" },
        { "path": "packages/verticals/brewery/recipes-ui", "mode": "npm" },
        { "path": "packages/platform/test-mcp", "mode": "npm" }
      ]
    },
    {
      "id": "sdk-publish-prep",
      "needsRootInstall": true,
      "commands": [
        "npm run build:packages",
        "npm run test:packages",
        "npm test -w @umbraculum/automation-contracts",
        "npm test -w @umbraculum/i18n-keys",
        "npm pack -w @umbraculum/ai-tool-sdk --dry-run",
        "npm pack -w @umbraculum/i18n-keys --dry-run",
        "npm pack -w @umbraculum/module-sdk --dry-run",
        "npm pack -w @umbraculum/automation-contracts --dry-run",
        "npm pack -w @umbraculum/pim-contracts --dry-run",
        "npm pack -w @umbraculum/mrp-contracts --dry-run",
        "npm pack -w @umbraculum/crp-contracts --dry-run",
        "npm pack -w @umbraculum/api-client --dry-run"
      ]
    },
    {
      "id": "dogfood-npm-smoke",
      "commands": ["./scripts/dogfood-npm-smoke.sh"]
    }
  ]
}
