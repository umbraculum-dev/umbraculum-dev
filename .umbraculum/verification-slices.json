{
  "schemaVersion": 1,
  "slices": {
    "contracts": {
      "pathPrefixes": ["packages/platform/contracts/"],
      "tiers": {
        "T0": [
          {
            "id": "contracts-test",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/contracts --include-workspace-root && npm test -w @umbraculum/contracts'"
          }
        ],
        "T1": [
          {
            "id": "contracts-build",
            "cmd": "./scripts/build-package-in-docker.sh @umbraculum/contracts --include-dependents"
          },
          {
            "id": "contracts-dist-check",
            "cmd": "./scripts/check-packages-dist-up-to-date.sh --no-dependents"
          },
          {
            "id": "contracts-test",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/contracts --include-workspace-root && npm test -w @umbraculum/contracts'"
          }
        ]
      }
    },
    "openapi": {
      "pathPrefixes": [
        "services/api/src/routes/",
        "services/api/src/modules/brewery/routes/",
        "services/api/src/openapi/",
        "services/api/openapi/",
        "packages/platform/api-client/",
        "packages/verticals/brewery/api-client/",
        "packages/platform/contracts/src/auth/",
        "packages/platform/contracts/src/workspaces/",
        "packages/verticals/brewery/contracts/src/brewery/",
        "packages/verticals/brewery/contracts/src/water/",
        "packages/verticals/brewery/contracts/src/analysis/",
        "packages/platform/contracts/src/billing/",
        "packages/platform/contracts/src/ads/",
        "packages/platform/contracts/src/ai/",
        "packages/platform/contracts/src/integrations/",
        "packages/platform/contracts/src/webhooks/",
        "packages/platform/contracts/src/platformAdmin/"
      ],
      "tiers": {
        "T0": [
          {
            "id": "api-test-unit",
            "cmd": "docker compose exec -T api sh -c 'cd /app && npm run test:unit'"
          }
        ],
        "T1": [
          {
            "id": "openapi-check",
            "cmd": "docker compose exec -T api sh -c 'cd /app && npm run openapi:check'"
          },
          {
            "id": "openapi-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && npm run test:unit -- src/tests/openapi.test.ts && npm run test:integration -- src/tests/authSessions.test.ts src/tests/accounts.test.ts'"
          },
          {
            "id": "api-client-openapi-codegen-check",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/api-client --include-workspace-root && npm run openapi:codegen:check -w @umbraculum/api-client'"
          },
          {
            "id": "brewery-api-client-openapi-codegen-check",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/brewery-api-client --include-workspace-root && npm run openapi:codegen:check -w @umbraculum/brewery-api-client'"
          }
        ]
      }
    },
    "api-platform": {
      "pathPrefixes": [
        "services/api/src/routes/auth.ts",
        "services/api/src/routes/workspaces.ts"
      ],
      "tiers": {
        "T0": [
          {
            "id": "platform-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && vitest run src/tests/authSessions.test.ts src/tests/accounts.test.ts'"
          }
        ],
        "T1": [
          {
            "id": "platform-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && vitest run src/tests/authSessions.test.ts src/tests/accounts.test.ts'"
          },
          {
            "id": "health-endpoint",
            "cmd": "curl -sf http://localhost:18080/api/health | grep -q '\"ok\":true'"
          }
        ]
      }
    },
    "api-brewery-batch1": {
      "pathPrefixes": [
        "services/api/src/routes/styles.ts",
        "services/api/src/routes/equipmentProfiles.ts",
        "services/api/src/routes/inventory.ts",
        "services/api/src/routes/brewdaySettings.ts",
        "services/api/src/routes/recipes.ts",
        "services/api/src/routes/recipesExport.ts"
      ],
      "tiers": {
        "T0": [
          {
            "id": "brewery-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && vitest run src/tests/equipmentProfiles.test.ts src/tests/inventory.test.ts src/tests/brewdaySettings.test.ts src/tests/recipes.test.ts src/tests/recipesExport.test.ts'"
          }
        ],
        "T1": [
          {
            "id": "brewery-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && vitest run src/tests/equipmentProfiles.test.ts src/tests/inventory.test.ts src/tests/brewdaySettings.test.ts src/tests/recipes.test.ts src/tests/recipesExport.test.ts'"
          }
        ]
      }
    },
    "packages-pim": {
      "pathPrefixes": ["packages/modules/pim-contracts/"],
      "tiers": {
        "T0": [
          {
            "id": "pim-test",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/pim-contracts --include-workspace-root && npm test -w @umbraculum/pim-contracts'"
          }
        ],
        "T1": [
          {
            "id": "pim-build",
            "cmd": "./scripts/build-package-in-docker.sh @umbraculum/pim-contracts"
          },
          {
            "id": "pim-test",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm install --no-audit --no-fund --prefer-offline -w @umbraculum/pim-contracts --include-workspace-root && npm test -w @umbraculum/pim-contracts'"
          },
          {
            "id": "pim-api-vitest",
            "cmd": "docker compose exec -T api sh -c 'cd /app && vitest run src/tests/pimProducts.test.ts src/tests/pimVariants.test.ts src/tests/pimAttributeSets.test.ts src/tests/pimCategories.test.ts'"
          }
        ]
      }
    },
    "docs": {
      "pathPrefixes": ["docs/", "README.md"],
      "tiers": {
        "T1": [
          {
            "id": "docs-readmes",
            "cmd": "npx @umbraculum/ci-parity@^1 run --jobs docs-readmes"
          }
        ]
      }
    },
    "docs-site": {
      "pathPrefixes": ["docs-site/"],
      "tiers": {
        "T1": [
          {
            "id": "docs-site-build",
            "cmd": "./scripts/docker-npm-run.sh -r 'npm run build -w @umbraculum/docs-site'"
          }
        ]
      }
    },
    "sdk-dist": {
      "pathPrefixes": ["packages/"],
      "tiers": {
        "T1": [
          {
            "id": "scoped-dist-check",
            "cmd": "./scripts/check-packages-dist-up-to-date.sh"
          }
        ]
      }
    }
  }
}
